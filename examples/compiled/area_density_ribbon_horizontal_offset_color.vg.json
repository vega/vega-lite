{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "background": "white",
  "padding": 5,
  "height": 240,
  "title": {
    "text": "Body Mass Density Ribbons by Species and Sex",
    "frame": "group"
  },
  "style": "cell",
  "data": [
    {
      "name": "source_0",
      "url": "data/penguins.json",
      "format": {"type": "json", "parse": {"Sex": "string"}},
      "transform": [
        {
          "type": "filter",
          "expr": "indexof([\"MALE\",\"FEMALE\"], datum[\"Sex\"]) !== -1"
        },
        {
          "type": "kde",
          "field": "Body Mass (g)",
          "groupby": ["Species", "Sex"],
          "resolve": "independent",
          "bandwidth": 100,
          "as": ["value", "density"]
        }
      ]
    }
  ],
  "signals": [
    {"name": "x_step", "update": "70 * domain('xOffset').length / (1-0.2)"},
    {
      "name": "width",
      "update": "bandspace(domain('x').length, 0.2, 0.2) * x_step"
    }
  ],
  "marks": [
    {
      "name": "pathgroup",
      "type": "group",
      "from": {
        "facet": {
          "name": "faceted_path_main",
          "data": "source_0",
          "groupby": ["Sex", "Species"]
        }
      },
      "encode": {
        "update": {
          "width": {"field": {"group": "width"}},
          "height": {"field": {"group": "height"}}
        }
      },
      "marks": [
        {
          "name": "marks",
          "type": "area",
          "style": ["area"],
          "sort": {"field": "y"},
          "from": {"data": "faceted_path_main"},
          "encode": {
            "update": {
              "opacity": {"value": 0.9},
              "orient": {"value": "horizontal"},
              "fill": {"scale": "color", "field": "Sex"},
              "description": {
                "signal": "\"Species: \" + (isValid(datum[\"Species\"]) ? isArray(datum[\"Species\"]) ? join(datum[\"Species\"], ' ') : datum[\"Species\"] : \"\"+datum[\"Species\"]) + \"; Body Mass (g): \" + (format(datum[\"value\"], \"\")) + \"; Sex: \" + (isValid(datum[\"Sex\"]) ? isArray(datum[\"Sex\"]) ? join(datum[\"Sex\"], ' ') : datum[\"Sex\"] : \"\"+datum[\"Sex\"]) + \"; density: \" + (format(datum[\"density\"], \"\"))"
              },
              "y": {"scale": "y", "field": "value"},
              "x": {
                "scale": "x",
                "field": "Species",
                "offset": {
                  "signal": "scale(\"xOffset\", datum[\"Sex\"]) + (scale(\"size\", datum[\"density\"])) * (0.5)"
                }
              },
              "x2": {
                "scale": "x",
                "field": "Species",
                "offset": {
                  "signal": "scale(\"xOffset\", datum[\"Sex\"]) + (scale(\"size\", datum[\"density\"])) * (-0.5)"
                }
              },
              "defined": {
                "signal": "isValid(datum[\"value\"]) && isFinite(+datum[\"value\"]) && isValid(datum[\"density\"]) && isFinite(+datum[\"density\"])"
              }
            }
          }
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "band",
      "domain": {"data": "source_0", "field": "Species", "sort": true},
      "range": {"step": {"signal": "x_step"}},
      "paddingInner": 0.2,
      "paddingOuter": 0.2
    },
    {
      "name": "y",
      "type": "linear",
      "domain": {"data": "source_0", "field": "value"},
      "range": [{"signal": "height"}, 0],
      "nice": true,
      "zero": false
    },
    {
      "name": "xOffset",
      "type": "point",
      "domain": {"data": "source_0", "field": "Sex", "sort": true},
      "range": {"step": 70},
      "paddingOuter": 0.5
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "source_0", "field": "Sex", "sort": true},
      "range": "category"
    },
    {
      "name": "size",
      "type": "linear",
      "domain": {"data": "source_0", "field": "density"},
      "range": [
        0,
        {
          "signal": "domain('xOffset').length > 1 ? abs(scale('xOffset', domain('xOffset')[1]) - scale('xOffset', domain('xOffset')[0])) : span(range('xOffset'))"
        }
      ],
      "zero": true
    }
  ],
  "axes": [
    {
      "scale": "y",
      "orient": "left",
      "gridScale": "x",
      "grid": true,
      "tickCount": {"signal": "ceil(height/40)"},
      "domain": false,
      "labels": false,
      "aria": false,
      "maxExtent": 0,
      "minExtent": 0,
      "ticks": false,
      "zindex": 0
    },
    {
      "scale": "x",
      "orient": "bottom",
      "grid": false,
      "title": "Species",
      "labelAlign": "right",
      "labelAngle": 270,
      "labelBaseline": "middle",
      "zindex": 0
    },
    {
      "scale": "y",
      "orient": "left",
      "grid": false,
      "title": "Body Mass (g)",
      "labelOverlap": true,
      "tickCount": {"signal": "ceil(height/40)"},
      "zindex": 0
    }
  ],
  "legends": [
    {
      "fill": "color",
      "symbolType": "circle",
      "title": "Sex",
      "encode": {"symbols": {"update": {"opacity": {"value": 0.9}}}}
    }
  ]
}
