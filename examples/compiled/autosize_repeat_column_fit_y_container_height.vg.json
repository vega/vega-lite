{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": "fit-y",
  "background": "white",
  "padding": 5,
  "height": 280,
  "data": [
    {
      "name": "source_0",
      "url": "data/cars.json",
      "format": {"type": "json"},
      "transform": [
        {
          "type": "extent",
          "field": "Miles_per_Gallon",
          "signal": "child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_extent"
        },
        {
          "type": "bin",
          "field": "Miles_per_Gallon",
          "as": [
            "bin_maxbins_10_Miles_per_Gallon",
            "bin_maxbins_10_Miles_per_Gallon_end"
          ],
          "signal": "child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_bins",
          "extent": {
            "signal": "child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_extent"
          },
          "maxbins": 10
        },
        {
          "type": "extent",
          "field": "Horsepower",
          "signal": "child__column_Horsepower_bin_maxbins_10_Horsepower_extent"
        },
        {
          "type": "bin",
          "field": "Horsepower",
          "as": ["bin_maxbins_10_Horsepower", "bin_maxbins_10_Horsepower_end"],
          "signal": "child__column_Horsepower_bin_maxbins_10_Horsepower_bins",
          "extent": {
            "signal": "child__column_Horsepower_bin_maxbins_10_Horsepower_extent"
          },
          "maxbins": 10
        }
      ]
    },
    {
      "name": "data_0",
      "source": "source_0",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "bin_maxbins_10_Miles_per_Gallon",
            "bin_maxbins_10_Miles_per_Gallon_end"
          ],
          "ops": ["count"],
          "fields": [null],
          "as": ["__count"]
        },
        {
          "type": "filter",
          "expr": "isValid(datum[\"bin_maxbins_10_Miles_per_Gallon\"]) && isFinite(+datum[\"bin_maxbins_10_Miles_per_Gallon\"])"
        }
      ]
    },
    {
      "name": "data_1",
      "source": "source_0",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "bin_maxbins_10_Horsepower",
            "bin_maxbins_10_Horsepower_end"
          ],
          "ops": ["count"],
          "fields": [null],
          "as": ["__count"]
        },
        {
          "type": "filter",
          "expr": "isValid(datum[\"bin_maxbins_10_Horsepower\"]) && isFinite(+datum[\"bin_maxbins_10_Horsepower\"])"
        }
      ]
    }
  ],
  "signals": [{"name": "childWidth", "value": 300}],
  "layout": {"padding": 20, "columns": 2, "bounds": "full", "align": "all"},
  "marks": [
    {
      "type": "group",
      "name": "child__column_Horsepower_group",
      "style": "cell",
      "encode": {
        "update": {
          "width": {"signal": "childWidth"},
          "height": {"signal": "height"}
        }
      },
      "marks": [
        {
          "name": "child__column_Horsepower_marks",
          "type": "rect",
          "style": ["bar"],
          "from": {"data": "data_1"},
          "encode": {
            "update": {
              "fill": {"value": "#4c78a8"},
              "ariaRoleDescription": {"value": "bar"},
              "description": {
                "signal": "\"Count of Records: \" + (format(datum[\"__count\"], \"\")) + \"; Horsepower (binned): \" + (!isValid(datum[\"bin_maxbins_10_Horsepower\"]) || !isFinite(+datum[\"bin_maxbins_10_Horsepower\"]) ? \"null\" : format(datum[\"bin_maxbins_10_Horsepower\"], \"\") + \" – \" + format(datum[\"bin_maxbins_10_Horsepower_end\"], \"\"))"
              },
              "x": {"scale": "child__column_Horsepower_x", "field": "__count"},
              "x2": {"scale": "child__column_Horsepower_x", "value": 0},
              "y2": {
                "scale": "child__column_Horsepower_y",
                "field": "bin_maxbins_10_Horsepower",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower_end\"]) - scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower\"])) < 0.25 ? 0.5 * (0.25 - (abs(scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower_end\"]) - scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower\"])))) : -0.5)"
                }
              },
              "y": {
                "scale": "child__column_Horsepower_y",
                "field": "bin_maxbins_10_Horsepower_end",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower_end\"]) - scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower\"])) < 0.25 ? -0.5 * (0.25 - (abs(scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower_end\"]) - scale(\"child__column_Horsepower_y\", datum[\"bin_maxbins_10_Horsepower\"])))) : 0.5)"
                }
              }
            }
          }
        }
      ],
      "axes": [
        {
          "scale": "child__column_Horsepower_x",
          "orient": "bottom",
          "gridScale": "child__column_Horsepower_y",
          "grid": true,
          "tickCount": {"signal": "ceil(childWidth/40)"},
          "domain": false,
          "labels": false,
          "aria": false,
          "maxExtent": 0,
          "minExtent": 0,
          "ticks": false,
          "zindex": 0
        },
        {
          "scale": "child__column_Horsepower_x",
          "orient": "bottom",
          "grid": false,
          "title": "Count of Records",
          "labelFlush": true,
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(childWidth/40)"},
          "zindex": 0
        },
        {
          "scale": "child__column_Horsepower_y",
          "orient": "left",
          "grid": false,
          "title": "Horsepower (binned)",
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(height/10)"},
          "zindex": 0
        }
      ]
    },
    {
      "type": "group",
      "name": "child__column_Miles_per_Gallon_group",
      "style": "cell",
      "encode": {
        "update": {
          "width": {"signal": "childWidth"},
          "height": {"signal": "height"}
        }
      },
      "marks": [
        {
          "name": "child__column_Miles_per_Gallon_marks",
          "type": "rect",
          "style": ["bar"],
          "from": {"data": "data_0"},
          "encode": {
            "update": {
              "fill": {"value": "#4c78a8"},
              "ariaRoleDescription": {"value": "bar"},
              "description": {
                "signal": "\"Count of Records: \" + (format(datum[\"__count\"], \"\")) + \"; Miles_per_Gallon (binned): \" + (!isValid(datum[\"bin_maxbins_10_Miles_per_Gallon\"]) || !isFinite(+datum[\"bin_maxbins_10_Miles_per_Gallon\"]) ? \"null\" : format(datum[\"bin_maxbins_10_Miles_per_Gallon\"], \"\") + \" – \" + format(datum[\"bin_maxbins_10_Miles_per_Gallon_end\"], \"\"))"
              },
              "x": {
                "scale": "child__column_Miles_per_Gallon_x",
                "field": "__count"
              },
              "x2": {"scale": "child__column_Miles_per_Gallon_x", "value": 0},
              "y2": {
                "scale": "child__column_Miles_per_Gallon_y",
                "field": "bin_maxbins_10_Miles_per_Gallon",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon_end\"]) - scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon\"])) < 0.25 ? 0.5 * (0.25 - (abs(scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon_end\"]) - scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon\"])))) : -0.5)"
                }
              },
              "y": {
                "scale": "child__column_Miles_per_Gallon_y",
                "field": "bin_maxbins_10_Miles_per_Gallon_end",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon_end\"]) - scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon\"])) < 0.25 ? -0.5 * (0.25 - (abs(scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon_end\"]) - scale(\"child__column_Miles_per_Gallon_y\", datum[\"bin_maxbins_10_Miles_per_Gallon\"])))) : 0.5)"
                }
              }
            }
          }
        }
      ],
      "axes": [
        {
          "scale": "child__column_Miles_per_Gallon_x",
          "orient": "bottom",
          "gridScale": "child__column_Miles_per_Gallon_y",
          "grid": true,
          "tickCount": {"signal": "ceil(childWidth/40)"},
          "domain": false,
          "labels": false,
          "aria": false,
          "maxExtent": 0,
          "minExtent": 0,
          "ticks": false,
          "zindex": 0
        },
        {
          "scale": "child__column_Miles_per_Gallon_x",
          "orient": "bottom",
          "grid": false,
          "title": "Count of Records",
          "labelFlush": true,
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(childWidth/40)"},
          "zindex": 0
        },
        {
          "scale": "child__column_Miles_per_Gallon_y",
          "orient": "left",
          "grid": false,
          "title": "Miles_per_Gallon (binned)",
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(height/10)"},
          "zindex": 0
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "child__column_Horsepower_x",
      "type": "linear",
      "domain": {"data": "data_1", "field": "__count"},
      "range": [0, {"signal": "childWidth"}],
      "nice": true,
      "zero": true
    },
    {
      "name": "child__column_Horsepower_y",
      "type": "linear",
      "domain": {
        "signal": "[child__column_Horsepower_bin_maxbins_10_Horsepower_bins.start, child__column_Horsepower_bin_maxbins_10_Horsepower_bins.stop]"
      },
      "range": [{"signal": "height"}, 0],
      "bins": {
        "signal": "child__column_Horsepower_bin_maxbins_10_Horsepower_bins"
      },
      "zero": false
    },
    {
      "name": "child__column_Miles_per_Gallon_x",
      "type": "linear",
      "domain": {"data": "data_0", "field": "__count"},
      "range": [0, {"signal": "childWidth"}],
      "nice": true,
      "zero": true
    },
    {
      "name": "child__column_Miles_per_Gallon_y",
      "type": "linear",
      "domain": {
        "signal": "[child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_bins.start, child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_bins.stop]"
      },
      "range": [{"signal": "height"}, 0],
      "bins": {
        "signal": "child__column_Miles_per_Gallon_bin_maxbins_10_Miles_per_Gallon_bins"
      },
      "zero": false
    }
  ]
}
