{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "autosize": {"type": "fit-x", "contains": "padding"},
  "background": "white",
  "padding": 5,
  "data": [
    {"name": "source_0", "url": "data/movies.json", "format": {"type": "json"}},
    {
      "name": "data_0",
      "source": "source_0",
      "transform": [
        {
          "type": "extent",
          "field": "Worldwide Gross",
          "signal": "concat_0_bin_maxbins_10_Worldwide_Gross_extent"
        },
        {
          "type": "bin",
          "field": "Worldwide Gross",
          "as": [
            "bin_maxbins_10_Worldwide Gross",
            "bin_maxbins_10_Worldwide Gross_end"
          ],
          "signal": "concat_0_bin_maxbins_10_Worldwide_Gross_bins",
          "extent": {
            "signal": "concat_0_bin_maxbins_10_Worldwide_Gross_extent"
          },
          "maxbins": 10
        },
        {
          "type": "aggregate",
          "groupby": [
            "bin_maxbins_10_Worldwide Gross",
            "bin_maxbins_10_Worldwide Gross_end"
          ],
          "ops": ["count"],
          "fields": [null],
          "as": ["__count"]
        },
        {
          "type": "filter",
          "expr": "isValid(datum[\"bin_maxbins_10_Worldwide Gross\"]) && isFinite(+datum[\"bin_maxbins_10_Worldwide Gross\"])"
        }
      ]
    },
    {
      "name": "data_1",
      "source": "source_0",
      "transform": [
        {
          "type": "filter",
          "expr": "isValid(datum[\"Worldwide Gross\"]) && isFinite(+datum[\"Worldwide Gross\"])"
        }
      ]
    }
  ],
  "signals": [
    {
      "name": "width",
      "init": "isFinite(containerSize()[0]) ? containerSize()[0] : 300",
      "on": [
        {
          "update": "isFinite(containerSize()[0]) ? containerSize()[0] : 300",
          "events": "window:resize"
        }
      ]
    },
    {"name": "concat_0_height", "value": 300},
    {"name": "concat_1_height", "value": 20}
  ],
  "layout": {"padding": 20, "columns": 1, "bounds": "full", "align": "each"},
  "marks": [
    {
      "type": "group",
      "name": "concat_0_group",
      "style": "cell",
      "encode": {
        "update": {
          "width": {"signal": "width"},
          "height": {"signal": "concat_0_height"}
        }
      },
      "marks": [
        {
          "name": "concat_0_marks",
          "type": "rect",
          "style": ["bar"],
          "from": {"data": "data_0"},
          "encode": {
            "update": {
              "fill": {"value": "#4c78a8"},
              "ariaRoleDescription": {"value": "bar"},
              "description": {
                "signal": "\"Worldwide Gross (binned): \" + (!isValid(datum[\"bin_maxbins_10_Worldwide Gross\"]) || !isFinite(+datum[\"bin_maxbins_10_Worldwide Gross\"]) ? \"null\" : format(datum[\"bin_maxbins_10_Worldwide Gross\"], \"\") + \" – \" + format(datum[\"bin_maxbins_10_Worldwide Gross_end\"], \"\")) + \"; Count of Records: \" + (format(datum[\"__count\"], \"\"))"
              },
              "x2": {
                "scale": "x",
                "field": "bin_maxbins_10_Worldwide Gross",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross_end\"]) - scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross\"])) < 0.25 ? -0.5 * (0.25 - (abs(scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross_end\"]) - scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross\"])))) : 0.5)"
                }
              },
              "x": {
                "scale": "x",
                "field": "bin_maxbins_10_Worldwide Gross_end",
                "offset": {
                  "signal": "0.5 + (abs(scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross_end\"]) - scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross\"])) < 0.25 ? 0.5 * (0.25 - (abs(scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross_end\"]) - scale(\"x\", datum[\"bin_maxbins_10_Worldwide Gross\"])))) : -0.5)"
                }
              },
              "y": {"scale": "concat_0_y", "field": "__count"},
              "y2": {"scale": "concat_0_y", "value": 0}
            }
          }
        }
      ],
      "axes": [
        {
          "scale": "concat_0_y",
          "orient": "left",
          "gridScale": "x",
          "grid": true,
          "tickCount": {"signal": "ceil(concat_0_height/40)"},
          "domain": false,
          "labels": false,
          "aria": false,
          "maxExtent": 0,
          "minExtent": 0,
          "ticks": false,
          "zindex": 0
        },
        {
          "scale": "concat_0_y",
          "orient": "left",
          "grid": false,
          "title": "Count of Records",
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(concat_0_height/40)"},
          "zindex": 0
        }
      ]
    },
    {
      "type": "group",
      "name": "concat_1_group",
      "style": "cell",
      "encode": {
        "update": {
          "width": {"signal": "width"},
          "height": {"signal": "concat_1_height"}
        }
      },
      "signals": [{"name": "height", "update": "concat_1_height"}],
      "marks": [
        {
          "name": "concat_1_marks",
          "type": "rect",
          "style": ["tick"],
          "from": {"data": "data_1"},
          "encode": {
            "update": {
              "opacity": {"value": 0.25},
              "fill": {"value": "#4c78a8"},
              "ariaRoleDescription": {"value": "tick"},
              "description": {
                "signal": "\"Worldwide Gross: \" + (format(datum[\"Worldwide Gross\"], \"\"))"
              },
              "yc": {"signal": "concat_1_height", "mult": 0.5},
              "height": {"signal": "0.75 * height"},
              "xc": {"scale": "x", "field": "Worldwide Gross"},
              "width": {"value": 1}
            }
          }
        }
      ],
      "axes": [
        {
          "scale": "x",
          "orient": "bottom",
          "grid": true,
          "tickCount": {"signal": "ceil(width/40)"},
          "domain": false,
          "labels": false,
          "aria": false,
          "maxExtent": 0,
          "minExtent": 0,
          "ticks": false,
          "zindex": 0
        },
        {
          "scale": "x",
          "orient": "bottom",
          "grid": false,
          "title": "Worldwide Gross",
          "labelFlush": true,
          "labelOverlap": true,
          "tickCount": {"signal": "ceil(width/40)"},
          "zindex": 0
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "linear",
      "domain": {
        "fields": [
          {
            "signal": "[concat_0_bin_maxbins_10_Worldwide_Gross_bins.start, concat_0_bin_maxbins_10_Worldwide_Gross_bins.stop]"
          },
          {"data": "data_1", "field": "Worldwide Gross"}
        ]
      },
      "range": [0, {"signal": "width"}],
      "bins": {"signal": "concat_0_bin_maxbins_10_Worldwide_Gross_bins"},
      "nice": true,
      "zero": false
    },
    {
      "name": "concat_0_y",
      "type": "linear",
      "domain": {"data": "data_0", "field": "__count"},
      "range": [{"signal": "concat_0_height"}, 0],
      "nice": true,
      "zero": true
    }
  ]
}
