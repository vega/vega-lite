{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "A treemap without size encoding (equally weighted leaves)",
  "background": "white",
  "padding": 5,
  "width": 960,
  "height": 500,
  "style": "view",
  "data": [
    {
      "name": "source_0",
      "url": "data/flare.json",
      "format": {"type": "json"},
      "transform": [
        {"type": "stratify", "key": "id", "parentKey": "parent"},
        {
          "type": "treemap",
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        },
        {"type": "filter", "expr": "!datum.children"}
      ]
    }
  ],
  "marks": [
    {
      "name": "marks",
      "type": "rect",
      "style": ["treemap"],
      "from": {"data": "source_0"},
      "encode": {
        "update": {
          "stroke": {"value": "#fff"},
          "strokeWidth": {"value": 1},
          "fill": {"scale": "color", "field": "name"},
          "tooltip": {
            "signal": "isValid(datum[\"name\"]) ? isArray(datum[\"name\"]) ? join(datum[\"name\"], '\\n') : datum[\"name\"] : \"\"+datum[\"name\"]"
          },
          "ariaRoleDescription": {"value": "treemap"},
          "description": {
            "signal": "\"name: \" + (isValid(datum[\"name\"]) ? isArray(datum[\"name\"]) ? join(datum[\"name\"], ' ') : datum[\"name\"] : \"\"+datum[\"name\"])"
          },
          "x": {"field": "x0"},
          "x2": {"field": "x1"},
          "y": {"field": "y0"},
          "y2": {"field": "y1"}
        }
      }
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "source_0", "field": "name", "sort": true},
      "range": "category"
    }
  ]
}
