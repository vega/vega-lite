{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "A word cloud using the default text field (no text encoding specified).",
  "background": "white",
  "padding": 5,
  "width": 600,
  "height": 400,
  "style": "view",
  "data": [
    {
      "name": "source_0",
      "values": [
        {"text": "visualization", "count": 80},
        {"text": "data", "count": 72},
        {"text": "chart", "count": 60},
        {"text": "graph", "count": 55},
        {"text": "analysis", "count": 50},
        {"text": "statistics", "count": 45},
        {"text": "interactive", "count": 42},
        {"text": "dashboard", "count": 38},
        {"text": "plot", "count": 35},
        {"text": "encoding", "count": 32},
        {"text": "scale", "count": 30},
        {"text": "axis", "count": 28},
        {"text": "legend", "count": 25},
        {"text": "color", "count": 22},
        {"text": "mark", "count": 20},
        {"text": "transform", "count": 18},
        {"text": "filter", "count": 16},
        {"text": "aggregate", "count": 15},
        {"text": "selection", "count": 14},
        {"text": "tooltip", "count": 12}
      ]
    }
  ],
  "marks": [
    {
      "name": "marks",
      "type": "text",
      "style": ["wordcloud"],
      "from": {"data": "source_0"},
      "encode": {
        "update": {
          "fill": {"scale": "color", "field": "text"},
          "ariaRoleDescription": {"value": "wordcloud"},
          "description": {
            "signal": "\"text: \" + (isValid(datum[\"text\"]) ? isArray(datum[\"text\"]) ? join(datum[\"text\"], ' ') : datum[\"text\"] : \"\"+datum[\"text\"]) + \"; count: \" + (format(datum[\"count\"], \"\"))"
          },
          "text": {"field": "text"},
          "align": {"value": "center"},
          "baseline": {"value": "alphabetic"},
          "x": {"field": "x"},
          "y": {"field": "y"},
          "fontSize": {"field": "fontSize"},
          "angle": {"field": "rotate"},
          "font": {"field": "font"},
          "fontStyle": {"field": "fontStyle"},
          "fontWeight": {"field": "fontWeight"}
        }
      },
      "transform": [
        {
          "type": "wordcloud",
          "size": [{"signal": "width"}, {"signal": "height"}],
          "text": {"field": "datum.text"},
          "fontSize": {"field": "datum.count"},
          "fontSizeRange": [14, 56],
          "rotate": {"signal": "~~(random() * 3) * 45 - 45"},
          "padding": 2
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "source_0", "field": "text", "sort": true},
      "range": "category"
    }
  ]
}
