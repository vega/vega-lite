{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Body Mass Density Ribbons by Species and Sex",
  "width": {"step": 90},
  "height": 240,
  "data": {"url": "data/penguins.json"},
  "transform": [
    {"filter": {"field": "Species", "oneOf": ["Adelie", "Gentoo"]}},
    {
      "density": "Body Mass (g)",
      "groupby": ["Species", "Sex"],
      "resolve": "independent",
      "extent": [2500, 6500]
    }
  ],
  "mark": {"type": "area", "opacity": 0.45},
  "encoding": {
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Body Mass (g)"
    },
    "x": {"field": "Species", "type": "nominal"},
    "xOffset": {"field": "Sex", "type": "nominal"},
    "size": {"field": "density", "type": "quantitative"},
    "color": {"field": "Sex", "type": "nominal"}
  }
}
