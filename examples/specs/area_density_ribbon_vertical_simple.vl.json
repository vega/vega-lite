{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Body Mass Violin Plot by Species",
  "width": 300,
  "data": {"url": "data/penguins.json"},
  "transform": [
    {
      "density": "Body Mass (g)",
      "groupby": ["Species"],
      "resolve": "independent"
    }
  ],
  "mark": {"type": "area"},
  "encoding": {
    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "Body Mass (g)"
    },
    "y": {"field": "Species", "type": "nominal"},
    "size": {"field": "density", "type": "quantitative"}
  }
}
