{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Body Mass Density Ribbons by Species",
  "width": 420,
  "height": {"step": 70},
  "data": {"url": "data/penguins.json"},
  "transform": [
    {"filter": {"field": "Species", "oneOf": ["Adelie", "Gentoo"]}},
    {
      "density": "Body Mass (g)",
      "groupby": ["Species"],
      "resolve": "independent",
      "extent": [2500, 6500]
    }
  ],
  "mark": {"type": "area", "opacity": 0.45},
  "encoding": {
    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "Body Mass (g)"
    },
    "y": {"field": "Species", "type": "nominal"},
    "size": {"field": "density", "type": "quantitative"}
  }
}
