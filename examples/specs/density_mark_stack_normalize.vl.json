{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Density Mark: Normalized Stack",
  "width": 420,
  "height": 180,
  "data": {
    "url": "data/penguins.json"
  },
  "mark": {
    "type": "density",
    "stack": "normalize"
  },
  "encoding": {
    "x": {
      "field": "Body Mass (g)",
      "type": "quantitative"
    },
    "fill": {
      "field": "Species",
      "type": "nominal"
    }
  }
}
