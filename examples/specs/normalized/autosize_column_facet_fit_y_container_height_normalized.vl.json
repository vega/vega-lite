{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "data": {"url": "data/cars.json"},
  "height": 300,
  "autosize": {"type": "fit-y"},
  "facet": {"column": {"field": "Origin", "type": "nominal"}},
  "spec": {
    "mark": "point",
    "encoding": {
      "x": {"field": "Horsepower", "type": "quantitative"},
      "y": {"field": "Miles_per_Gallon", "type": "quantitative"}
    }
  }
}