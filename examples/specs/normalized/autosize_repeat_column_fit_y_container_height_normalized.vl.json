{
  "data": {"url": "data/cars.json"},
  "align": "all",
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "height": 280,
  "autosize": {"type": "fit-y"},
  "columns": 2,
  "concat": [
    {
      "mark": "bar",
      "encoding": {
        "x": {"aggregate": "count", "type": "quantitative"},
        "y": {"bin": true, "field": "Horsepower", "type": "quantitative"}
      },
      "name": "child__column_Horsepower"
    },
    {
      "mark": "bar",
      "encoding": {
        "x": {"aggregate": "count", "type": "quantitative"},
        "y": {"bin": true, "field": "Miles_per_Gallon", "type": "quantitative"}
      },
      "name": "child__column_Miles_per_Gallon"
    }
  ]
}