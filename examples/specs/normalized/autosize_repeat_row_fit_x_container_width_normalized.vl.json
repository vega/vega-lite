{
  "data": {"url": "data/cars.json"},
  "align": "all",
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 340,
  "autosize": {"type": "fit-x"},
  "columns": 1,
  "concat": [
    {
      "mark": "bar",
      "encoding": {
        "x": {"bin": true, "field": "Horsepower", "type": "quantitative"},
        "y": {"aggregate": "count", "type": "quantitative"}
      },
      "name": "child__row_Horsepower"
    },
    {
      "mark": "bar",
      "encoding": {
        "x": {"bin": true, "field": "Miles_per_Gallon", "type": "quantitative"},
        "y": {"aggregate": "count", "type": "quantitative"}
      },
      "name": "child__row_Miles_per_Gallon"
    }
  ]
}