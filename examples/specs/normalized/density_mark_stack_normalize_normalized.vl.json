{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Density Mark: Normalized Stack",
  "width": 420,
  "height": 180,
  "data": {"url": "data/penguins.json"},
  "transform": [{"density": "Body Mass (g)", "groupby": ["Species"]}],
  "layer": [
    {
      "mark": {"type": "area", "orient": "vertical", "fillOpacity": 0.5},
      "encoding": {
        "x": {
          "field": "value",
          "type": "quantitative",
          "title": "Body Mass (g)"
        },
        "y": {"field": "density", "type": "quantitative", "stack": "normalize"},
        "fill": {"field": "Species", "type": "nominal"}
      }
    }
  ]
}