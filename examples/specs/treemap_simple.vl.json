{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "A simple treemap of the Flare class hierarchy",
  "width": 960,
  "height": 500,
  "data": {
    "url": "data/flare.json"
  },
  "mark": {
    "type": "treemap",
    "stroke": "#fff",
    "strokeWidth": 1
  },
  "encoding": {
    "hierarchy": {
      "key": {"field": "id"},
      "parentKey": {"field": "parent"}
    },
    "size": {"field": "size", "type": "quantitative"},
    "color": {"field": "name", "type": "nominal", "legend": null},
    "tooltip": [
      {"field": "name", "type": "nominal"},
      {"field": "size", "type": "quantitative"}
    ]
  }
}
